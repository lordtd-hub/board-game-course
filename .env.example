# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-long-random-string
ALLOWED_EMAIL_DOMAINS=sru.ac.th,student.sru.ac.th
BOOTSTRAP_SUPER_ADMIN_EMAIL=sittichoke.son@sru.ac.th

# Google OAuth for user login
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Google Sheets/Drive service account.
# Share the Sheet and root Drive folder with this service account email.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Public mobile exam (students do not sign in).
# Permanent signing secret. Room code and entry window are normally set from /instructor/exam-control.
EXAM_SECRET=replace-with-a-separate-long-random-string
EXAM_STORAGE_MODE=sheet
# SHA-256 of the 8-12 digit instructor control PIN.
EXAM_CONTROL_PIN_HASH=
# Optional legacy fallback when no saved exam_config exists:
EXAM_ROOM_CODE_HASH=
EXAM_OPEN_AT=
EXAM_CLOSE_AT=
# Development/fallback sections when Google Sheets is not configured: id:label,id:label
EXAM_SECTION_OPTIONS=SEC-1:Section 1,SEC-2:Section 2,SEC-3:Section 3
